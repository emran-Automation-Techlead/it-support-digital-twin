# Required: Voice Mode uses the ElevenLabs web widget, which only needs the agent ID.
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here

# Optional: not used by the web widget. Only needed if you later add
# Python SDK-based (server-side) voice features that call the ElevenLabs API directly.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
